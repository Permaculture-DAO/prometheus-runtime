{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Permaculture-DAO/prometheus-runtime/contracts/decoder.registry.schema.json",
  "title": "Prometheus Decoder Registry",
  "type": "object",
  "required": ["registry_id", "version", "status", "decoders"],
  "additionalProperties": false,
  "properties": {
    "registry_id": {
      "type": "string",
      "pattern": "^PROM-DECODER-REGISTRY-[A-Za-z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9._-]+)?$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "frozen", "superseded"]
    },
    "decoders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "decoder_id",
          "version",
          "input_source",
          "output_event_schema",
          "authoritative_for_mrv",
          "test_vector_status"
        ],
        "additionalProperties": false,
        "properties": {
          "decoder_id": {
            "type": "string",
            "pattern": "^dec_[a-z0-9_\\-]+$"
          },
          "version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9._-]+)?$"
          },
          "input_source": {
            "type": "string",
            "enum": ["synthetic", "ttn_mqtt", "ttn_webhook", "manual_csv", "lab_pdf", "open_meteo", "copernicus_stac"]
          },
          "output_event_schema": {
            "type": "string",
            "const": "sensor.event.schema.json"
          },
          "authoritative_for_mrv": {
            "type": "boolean",
            "const": false
          },
          "test_vector_status": {
            "type": "string",
            "enum": ["missing", "synthetic_only", "candidate", "accepted"]
          }
        }
      }
    }
  }
}

