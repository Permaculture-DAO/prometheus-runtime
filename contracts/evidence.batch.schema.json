{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Permaculture-DAO/prometheus-runtime/contracts/evidence.batch.schema.json",
  "title": "Prometheus Synthetic Evidence Batch",
  "type": "object",
  "required": [
    "batch_id",
    "batch_type",
    "source_stage",
    "created_at",
    "event_count",
    "events",
    "event_ids_sha256",
    "batch_hash",
    "holochain_reference",
    "authoritative_for_mrv",
    "statement"
  ],
  "additionalProperties": false,
  "properties": {
    "batch_id": {
      "type": "string",
      "pattern": "^batch_[a-z0-9_\\-]+$"
    },
    "batch_type": {
      "type": "string",
      "const": "synthetic_evidence_reference"
    },
    "source_stage": {
      "type": "string",
      "const": "S6 draft"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_count": {
      "type": "integer",
      "minimum": 1
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_id", "source_system", "event_type", "event_sha256"],
        "additionalProperties": false,
        "properties": {
          "event_id": {
            "type": "string",
            "pattern": "^evt_[a-f0-9]{64}$"
          },
          "source_system": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "event_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "event_ids_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "batch_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "holochain_reference": {
      "type": "object",
      "required": ["mode", "commit_performed", "entry_ref", "reference_hash"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "const": "simulated_reference_only"
        },
        "commit_performed": {
          "type": "boolean",
          "const": false
        },
        "entry_ref": {
          "type": "null"
        },
        "reference_hash": {
          "type": "string",
          "pattern": "^hcref_[a-f0-9]{64}$"
        }
      }
    },
    "authoritative_for_mrv": {
      "type": "boolean",
      "const": false
    },
    "statement": {
      "type": "string",
      "const": "evaluation, not certification"
    }
  }
}
